# Axiado SoC drivers
#
menu "AXIADO SoC drivers"
	depends on ARCH_AXIADO || COMPILE_TEST

config SOC_AXIADO
	bool "Axiado SoC support"
	help
	  Say Y here if you want to build support for Axiado family of SoCs.
	  This option enables the base SoC support and is required for all
	  Axiado-specific drivers including SGPIO and other peripheral
	  drivers. The Axiado SoC family includes various security-focused
	  processors with integrated hardware security modules and specialized
	  I/O controllers.

if SOC_AXIADO

config AXIADO_LTPI
	tristate "Axiado LTPI GPIO driver"
	depends on GPIOLIB
	select GPIOLIB_IRQCHIP
	help
	  This driver provides GPIO support for Axiado LTPI (Low-Speed
	  Transport Protocol Interface) devices. LTPI is a protocol
	  for low-speed communication between devices.

	  This driver supports:
	  - GPIO input/output operations
	  - Interrupt handling for GPIO inputs
	  - Regmap-based register access
	  - Debug filesystem support for testing

	  If unsure, say N.

config AXIADO_LTPI_REGMAP
	bool "Enable regmap support for LTPI driver"
	depends on AXIADO_LTPI
	select REGMAP
	help
	  Enable regmap support for LTPI register access. This allows
	  the driver to use regmap for register operations instead of
	  direct memory mapping.

	  If unsure, say N.

config AXIADO_LTPI_DEBUGFS
	bool "Enable debug filesystem support for LTPI driver"
	depends on AXIADO_LTPI
	depends on DEBUG_FS
	help
	  Enable debug filesystem support for LTPI driver testing and
	  debugging. This creates debugfs entries for simulating
	  interrupts and dumping internal state.

	  This option is only useful for development and testing.
	  If unsure, say N.

config AXIADO_SGPIO
	bool "Axiado SGPIO support"
	depends on OF_GPIO
	select GPIO_GENERIC
	select GPIOLIB_IRQCHIP
	help
	  Enable support for Axiado Serial GPIO (SGPIO) controller.
	  SGPIO provides a serial interface for GPIO operations with support
	  for interrupt handling, and configurable data direction.
	  This driver supports both 128-bit design variants
	  and can work with either direct memory mapping
	  or regmap-based register access.

config AXIADO_SGPIO_REGMAP
	bool "Axiado SGPIO regmap support"
	depends on AXIADO_SGPIO
	select REGMAP
	help
	  Enable regmap support for Axiado SGPIO driver.
	  This option allows the SGPIO driver to work with MFD framework
	  using regmap for register access instead of direct
	  memory mapping. When enabled, the driver will attempt to use regmap
	  from the parent device for register operations, falling back to
	  direct memory mapping if regmap is not available. This is useful
	  when SGPIO is part of a larger MFD device with shared register space.

endif # SOC_AXIADO

endmenu
