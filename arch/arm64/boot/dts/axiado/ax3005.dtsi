		disp_ctrl: disp_ctrl@40c00000 {
			compatible = "axiado,drm-db9000";
			reg = <0x0 0x40c00000 0x0 0x1000>;
			memory-region = <&pci_ep_ctrl>;
			interrupts = <GIC_SPI 14 IRQ_TYPE_LEVEL_HIGH>;
			clocks = <&clk_mali &clk_pclk>;
			clock-names = "clk_mali", "clk_pclk";
			bits-per-pixel = <32>;
			bus-width = <24>;
			paddr-disp = <0x8c000000>;
			status = "disabled";
			disp_out: port {
				#address-cells = <1>;
				#size-cells = <0>;
				disp_out_hdmi: endpoint@0 {
					reg = <0>;
					remote-endpoint = <&hdmi_in_disp>;
				};
			};
		};

		hdmi: hdmi@40c11000 {
			compatible ="axiado,ax3000-hdmi";
			reg = <0x00 0x40c11000 0x00 0x4000>;
			memory-region = <&pci_ep_ctrl>;
			interrupts = <GIC_SPI 16 IRQ_TYPE_LEVEL_HIGH>;
			clocks =  <&clk_mali>, <&clk_pclk>;
			clock-names = "clk_mali", "clk_pclk";
			#address-cells = <1>;
			#size-cells = <0>;
			status = "disabled";
			hdmi_in: port@0 {
				#address-cells = <1>;
				#size-cells = <0>;
				hdmi_in_disp: endpoint@0 {
					reg = <0>;
					remote-endpoint = <&disp_out_hdmi>;
				};
			};
		};

		pcie_x1: pcie@45200000 {
			compatible = "axiado,ax3005-pcie";
			status = "okay";
			device_type = "pci";
			device_role = "vga";                    /* VGA Controller */
			reg = <0 0x45200000 0 0x1000>,          /* PADS XPA reg */
			      <0 0x45300000 0 0x4000>,        /* AFI PHY reg */
			      <0 0x45203000 0 0x1000>,        /* int cfg space */
			      <0 0x45202000 0 0x1000>,        /* bridge reg */
			      <0 0x45280000 0 0x8000>,        /* MBX reg */
			      <0 0x45240000 0 0x1000>,        /* EXT reg */
			      <0 0x33202400 0 0x100>;		/* IOCTL reg */
			reg-names = "csr", "phy", "cfg", "bridge", "mbx", "ext", "ioctl";
			#address-cells = <3>;
			#size-cells = <2>;
			interrupt-parent = <&gic500>;
			interrupts = <GIC_SPI 33 IRQ_TYPE_LEVEL_HIGH>,  /* MSI interrupt */
				     <GIC_SPI 34 IRQ_TYPE_LEVEL_HIGH>,       /* Msgbox */
				     <GIC_SPI 40 IRQ_TYPE_LEVEL_HIGH>;       /* Mailbox 0 */
			interrupt-names = "msi", "msgbox", "mailbox";
			interrupt-map-mask = <0 0 0 7>;
			interrupt-map = <0 0 0 1 &gic500 0>,
					<0 0 0 2 &gic500 1>,
					<0 0 0 3 &gic500 2>,
					<0 0 0 4 &gic500 3>;
			num-lanes = <1>;
			clocks = <&uartclk>;
			clock-names = "uartclk";
			bus-range = <0x00 0xff>;
			ranges = <0x83000000 0x0 0x89300000 0x0 0x89300000 0x0 0x100000>,   /* 1MB - BAR0 non-prefetchable */
				 <0xc3000000 0x0 0x8c000000 0x0 0x8c000000 0x0 0x4000000>; /* 64MB - BAR2 prefetchable */
			device_class = "vga";
			pci0: pci@1,0 {
				device_type = "pci";
				assigned-addresses = <0x83000800 0x7 0xE0000000 0x0 0x400000>;
				reg = <0x00800 0 0 0 0>;
				#address-cells = <3>;
				#size-cells = <2>;
				ranges;
			};
		};

