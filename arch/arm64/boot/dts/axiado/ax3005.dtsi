			interrupt-parent = <&gic500>;
			interrupts = <GIC_SPI 160 IRQ_TYPE_LEVEL_HIGH>;
			reg = <0x00 0x33281400 0x00 0x400>;
			pwms = <&pwm10 0 400>;
			status = "disabled";
		};

		fan11: pwm-fan11 {
			compatible = "axiado,ax3000-pwm-fan";
			interrupt-parent = <&gic500>;
			interrupts = <GIC_SPI 161 IRQ_TYPE_LEVEL_HIGH>;
			reg = <0x00 0x33281800 0x00 0x400>;
			pwms = <&pwm11 0 400>;
			status = "disabled";
		};

		fan12: pwm-fan12 {
			compatible = "axiado,ax3000-pwm-fan";
			interrupt-parent = <&gic500>;
			interrupts = <GIC_SPI 162 IRQ_TYPE_LEVEL_HIGH>;
			reg = <0x00 0x33301400 0x00 0x400>;
			pwms = <&pwm12 0 400>;
			status = "disabled";
		};

		fan13: pwm-fan13 {
			compatible = "axiado,ax3000-pwm-fan";
			interrupt-parent = <&gic500>;
			interrupts = <GIC_SPI 163 IRQ_TYPE_LEVEL_HIGH>;
			reg = <0x00 0x33301800 0x00 0x400>;
			pwms = <&pwm13 0 400>;
			status = "disabled";
		};

		fan14: pwm-fan14 {
			compatible = "axiado,ax3000-pwm-fan";
			interrupt-parent = <&gic500>;
			interrupts = <GIC_SPI 164 IRQ_TYPE_LEVEL_HIGH>;
			reg = <0x00 0x33381400 0x00 0x400>;
			pwms = <&pwm14 0 400>;
			status = "disabled";
		};

		fan15: pwm-fan15 {
			compatible = "axiado,ax3000-pwm-fan";
			interrupt-parent = <&gic500>;
			interrupts = <GIC_SPI 165 IRQ_TYPE_LEVEL_HIGH>;
			reg = <0x00 0x33381800 0x00 0x400>;
			pwms = <&pwm15 0 400>;
			status = "disabled";
		};

		rtc0: rtc@33282000 {
			compatible = "cdns,rtc-r109v3";
			reg = <0x00 0x33282000 0x00 0x100>;
			clock-names = "pclk", "ref_clk";
			clocks = <&pclk &rtcclk>;
			interrupt-parent = <&gic500>;
			interrupts = <0 109 4>;
			status = "disabled";
		};

		saradc:saradc@331A0000 {
			compatible = "axiado,ax3000-saradc";
			reg = <0x00 0x331a0000 0x00 0x400>;
			interrupt-parent = <&gic500>;
			interrupts = <GIC_SPI 166 IRQ_TYPE_LEVEL_HIGH>;
			clocks = <&pclk &pclk>;
			clock-names = "refclk", "refclk";
			#io-channel-cells = <1>;
			status = "disabled";
		};

		spi0: spi@33010000 {
			compatible = "snps,dwc-ssi-1.01a";
			#address-cells = <1>;
			#size-cells = <0>;
			reg = <0x0 0x33010000 0x0 0x10000>;
			interrupt-parent = <&gic500>;
			interrupts = <GIC_SPI 115 IRQ_TYPE_LEVEL_HIGH>;
			clocks = <&spi_clk>;
			num-cs = <2>;
			reg-io-width = <4>;
			status = "disabled";
		};

		spi1: spi@33090000 {
			compatible = "snps,dwc-ssi-1.01a";
			reg = <0x0 0x33090000 0x0 0x10000>;
			interrupt-parent = <&gic500>;
			interrupts = <GIC_SPI 116 IRQ_TYPE_LEVEL_HIGH>;
			clocks = <&spi_clk>;
			num-cs = <1>;
			reg-io-width = <4>;
			status = "disabled";
		};

		spi2: spi@333c0000 {
			compatible = "snps,dwc-ssi-1.01a";
			reg = <0x0 0x333c0000 0x0 0x10000>;
			interrupt-parent = <&gic500>;
			interrupts = <GIC_SPI 117 IRQ_TYPE_LEVEL_HIGH>;
			clocks = <&spi_clk>;
			num-cs = <1>;
			reg-io-width = <4>;
			status = "disabled";
		};

		spi3: spi@330e0000 {
			compatible = "snps,dwc-ssi-1.01a";
			reg = <0x0 0x330e0000 0x0 0x10000>;
			interrupt-parent = <&gic500>;
			interrupts = <GIC_SPI 118 IRQ_TYPE_LEVEL_HIGH>;
			clocks = <&spi_clk>;
			num-cs = <1>;
			reg-io-width = <4>;
			status = "disabled";
		};

		spi5: spi@33390000 {
			compatible = "snps,dwc-ssi-1.01a";
			reg = <0x0 0x33390000 0x0 0x10000>;
			#address-cells = <1>;
			#size-cells = <0>;
			interrupt-parent = <&gic500>;
			interrupts = <GIC_SPI 119 IRQ_TYPE_LEVEL_HIGH>;
			clocks = <&spi_clk>;
			num-cs = <2>;
			reg-io-width = <4>;
			status = "disabled";
		};

		spi6: spi@333a0000 {
			compatible = "snps,dwc-ssi-1.01a";
			reg = <0x0 0x333a0000 0x0 0x10000>;
			interrupt-parent = <&gic500>;
			interrupts = <GIC_SPI 120 IRQ_TYPE_LEVEL_HIGH>;
			clocks = <&spi_clk>;
			num-cs = <1>;
			reg-io-width = <4>;
			status = "disabled";
		};

		sgpio0: sgpio@33201c00 {
			compatible = "axiado,sgpio";
			reg = <0x0 0x33201c00 0x00 0x400>;
			gpio-controller;
			#gpio-cells = <2>;
			interrupt-parent = <&gic500>;
			interrupts = <GIC_SPI 125 IRQ_TYPE_LEVEL_HIGH>;
			design-variant = <512>;
			/* Supports maximum of 128 pins */
			ngpios = <128>;
			/* SGPIO Clock Frequency 12 MHz */
			bus-frequency = <12000000>;
			apb-frequency = <100000000>;
			dout-init = <0x00000000 0x00000000 0x00000000 0x00000000>;
			status = "disabled";
		};

		emmc_phy: emmc-phy@33301c00 {
			compatible = "axiado,ax3000-emmc-phy";
			reg = <0x00 0x33301c00 0x00 0x100>;
			#phy-cells = <0>;
			status = "disabled";
		};

		sdhci0: mmc0@46000000 {
			compatible = "axiado,ax3000-sdhci-5.1-emmc", "arasan,sdhci-5.1";
			reg = <0x0 0x46000000 0x00 0x1000>;
			clock-names = "clk_xin", "clk_ahb";
			clocks = <&clk_xin &clk_xin>;
			interrupt-parent = <&gic500>;
			interrupts = <GIC_SPI 123 IRQ_TYPE_LEVEL_HIGH>;
			bus-width = <8>;
			phys = <&emmc_phy>;
			phy-names = "phy_arasan";
			status = "disabled";
		};

		/* HCP (Header and Crypto Processing Engine) */
		hcp: hcp@43000000 {
			compatible = "axiado,ax3000-hcp";
			#address-cells = <1>;
			#size-cells = <0>;
			/*
			 * All memory regions for the HCP subsystem:
			 * - EIP-197 crypto engine
			 * - SHIM registers
			 * - PHY CSR
			 */
			reg = <0x0 0x43000000 0x0 0x100000>,  /* EIP-197 (1MB) */
			      <0x0 0x43100000 0x0 0x4000>,    /* SHIM regs (16KB) */
			      <0x0 0x47000000 0x0 0x50000>;   /* PHY CSR (320KB) */
			reg-names = "eip197", "shim", "phy-csr";
			/*
			 * All interrupts for HCP:
			 * IRQ 0: EIP-197 crypto
			 * IRQ 1-4: Rings 0-3
			 * IRQ 5-9: MACs 0-4
			 * IRQ 230-237: Rings 4-11
			 */
			interrupt-parent = <&gic500>;
			interrupts = <GIC_SPI 0 IRQ_TYPE_LEVEL_HIGH>,     /* EIP-197 */
			             <GIC_SPI 1 IRQ_TYPE_LEVEL_HIGH>,     /* Ring 0 */
			             <GIC_SPI 2 IRQ_TYPE_LEVEL_HIGH>,     /* Ring 1 */
			             <GIC_SPI 3 IRQ_TYPE_LEVEL_HIGH>,     /* Ring 2 */
			             <GIC_SPI 4 IRQ_TYPE_LEVEL_HIGH>,     /* Ring 3 */
			             <GIC_SPI 5 IRQ_TYPE_LEVEL_HIGH>,     /* XGMII */
			             <GIC_SPI 6 IRQ_TYPE_LEVEL_HIGH>,     /* GMII0 */
			             <GIC_SPI 7 IRQ_TYPE_LEVEL_HIGH>,     /* GMII1 */
			             <GIC_SPI 8 IRQ_TYPE_LEVEL_HIGH>,     /* GMII2 */
			             <GIC_SPI 9 IRQ_TYPE_LEVEL_HIGH>,     /* GMII3 */
			             <GIC_SPI 230 IRQ_TYPE_LEVEL_HIGH>,   /* Ring 4 */
			             <GIC_SPI 231 IRQ_TYPE_LEVEL_HIGH>,   /* Ring 5 */
			             <GIC_SPI 232 IRQ_TYPE_LEVEL_HIGH>,   /* Ring 6 */
			             <GIC_SPI 233 IRQ_TYPE_LEVEL_HIGH>,   /* Ring 7 */
			             <GIC_SPI 234 IRQ_TYPE_LEVEL_HIGH>,   /* Ring 8 */
			             <GIC_SPI 235 IRQ_TYPE_LEVEL_HIGH>,   /* Ring 9 */
			             <GIC_SPI 236 IRQ_TYPE_LEVEL_HIGH>,   /* Ring 10 */
			             <GIC_SPI 237 IRQ_TYPE_LEVEL_HIGH>;   /* Ring 11 */
			interrupt-names = "eip197", "eip_ring0", "eip_ring1", "eip_ring2", "eip_ring3",
			                  "xgmii", "gmii0", "gmii1", "gmii2", "gmii3", "eip_ring4",
			                  "eip_ring5", "eip_ring6", "eip_ring7", "eip_ring8", "eip_ring9",
			                  "eip_ring10", "eip_ring11";

			/* MAC 0: 10G RXAUI */
			mac0: mac@0 {
				compatible = "axiado,ax3000-mac";
				reg = <0>;
				phy-mode = "rxaui";
				status = "disabled";
			};

			/* MAC 1: 1G SGMII */
			mac1: mac@1 {
				compatible = "axiado,ax3000-mac";
				reg = <1>;
				phy-mode = "sgmii";
				status = "disabled";
			};

			/* MAC 2: 1G SGMII */
			mac2: mac@2 {
				compatible = "axiado,ax3000-mac";
				reg = <2>;
				phy-mode = "sgmii";
				status = "disabled";
			};

			/* MAC 3: 1G SGMII */
			mac3: mac@3 {
				compatible = "axiado,ax3000-mac";
				reg = <3>;
				phy-mode = "sgmii";
				status = "disabled";
			};

			/* MAC 4: 1G SGMII */
			mac4: mac@4 {
				compatible = "axiado,ax3000-mac";
				reg = <4>;
				phy-mode = "sgmii";
				status = "disabled";
			};

			/* MDIO bus for PHY management */
			mdio: mdio {
				compatible = "axiado,ax3000-mdio";
				#address-cells = <1>;
				#size-cells = <0>;
			};

			hfifo: hfifo {
				compatible = "axiado,ax3000-hfifo";
				mac = <1>;
				status = "disabled";
			};
		};
	};

	video: video {
		compatible = "axiado,ax3000-video";
		memory-region = <&pci_ep_disp>;
	};
};
