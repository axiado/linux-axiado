/dts-v1/;

#include <dt-bindings/interrupt-controller/irq.h>
#include <dt-bindings/interrupt-controller/arm-gic.h>
/memreserve/ 0x80002fa0 0x00000008;
/ {
	model = "Axiado AX3005";
	interrupt-parent = <&gic500>;
	#address-cells = <2>;
	#size-cells = <2>;

	cpus {
		#address-cells = <2>;
		#size-cells = <0>;

		cpu0: cpu@0 {
			device_type = "cpu";
			compatible = "arm,cortex-a53";
			reg = <0x0 0x0>;
			enable-method = "spin-table";
			cpu-release-addr = <0x0 0x80002fa0>;
			d-cache-size = <0x8000>;
			d-cache-line-size = <64>;
			d-cache-sets = <128>;
			i-cache-size = <0x8000>;
			i-cache-line-size = <64>;
			i-cache-sets = <256>;
			next-level-cache = <&l2>;
		};

		cpu1: cpu@1 {
			device_type = "cpu";
			compatible = "arm,cortex-a53";
			reg = <0x0 0x1>;
			enable-method = "spin-table";
			cpu-release-addr = <0x0 0x80002fa0>;
			d-cache-size = <0x8000>;
			d-cache-line-size = <64>;
			d-cache-sets = <128>;
			i-cache-size = <0x8000>;
			i-cache-line-size = <64>;
			i-cache-sets = <256>;
			next-level-cache = <&l2>;
		};

		cpu2: cpu@2 {
			device_type = "cpu";
			compatible = "arm,cortex-a53";
			reg = <0x0 0x2>;
			enable-method = "spin-table";
			cpu-release-addr = <0x0 0x80002fa0>;
			d-cache-size = <0x8000>;
			d-cache-line-size = <64>;
			d-cache-sets = <128>;
			i-cache-size = <0x8000>;
			i-cache-line-size = <64>;
			i-cache-sets = <256>;
			next-level-cache = <&l2>;
		};

		cpu3: cpu@3 {
			device_type = "cpu";
			compatible = "arm,cortex-a53";
			reg = <0x0 0x3>;
			enable-method = "spin-table";
			cpu-release-addr = <0x0 0x80002fa0>;
			d-cache-size = <0x8000>;
			d-cache-line-size = <64>;
			d-cache-sets = <128>;
			i-cache-size = <0x8000>;
			i-cache-line-size = <64>;
			i-cache-sets = <256>;
			next-level-cache = <&l2>;
		};

		l2: l2-cache0 {
			compatible = "cache";
			cache-size = <0x100000>;
			cache-line-size = <64>;
			cache-sets = <1024>;
			cache-level = <2>;
		};
	};

	reserved-memory {
		#address-cells = <2>;
		#size-cells = <2>;
		ranges;
		pci_ep_disp: buffer@8c000000 {
			reg = <0x00 0x8c000000 0x00 0x4000000>; /* Data-64MB framebuffer */
			no-map;
		};
		pci_ep_ctrl: buffer@89300000 {
			reg = <0x00 0x89300000 0x00 0x100000>; /* Control-1MB */
			no-map;
		};
		rofs_memory: ramrofs@80B00000 {
                        reg = <0x00 0x80B00000 0x00 0x06400000>; /*MTD 100MB*/
                        no-map;
                };
	};

	display-subsystem {
		compatible = "axiado,display-subsystem";
		ports = <&disp_out>;
	};

	timer:timer {
		compatible = "arm,armv8-timer";
		interrupt-parent = <&gic500>;
		interrupts = <GIC_PPI 13 IRQ_TYPE_LEVEL_HIGH>,
			   <GIC_PPI 14 IRQ_TYPE_LEVEL_HIGH>,
			   <GIC_PPI 11 IRQ_TYPE_LEVEL_HIGH>,
			   <GIC_PPI 10 IRQ_TYPE_LEVEL_HIGH>;
		arm,cpu-registers-not-fw-configured;
	};

	clocks {
		refclk: refclk {
			compatible = "fixed-clock";
			#clock-cells = <0>;
			clock-frequency = <125000000>;
		};
		uartclk: uartclk {
			compatible = "fixed-clock";
			#clock-cells = <0>;
			clock-frequency = <10000000>;
		};
		pclk: pclk {
			compatible = "fixed-clock";
			#clock-cells = <0>;
			clock-frequency = <100000000>; /* 100MHz pclk */
		};
		sysclk: sysclk {
			compatible = "fixed-clock";
			#clock-cells = <0>;
			clock-frequency = <200000000>; /* 200MHz sysclk */
		};
		spi_clk: spi_clk {
			compatible = "fixed-clock";
			#clock-cells = <0>;
			clock-frequency = <400000000>;  /* 400MHz */
		};
		sp_dma_clk: sp_dma_clk {
			compatible = "fixed-clock";
			#clock-cells = <0>;
			clock-frequency = <3125000>;  /* 3.125 MHz */
		};
		clk_mali: clk_mali {
			compatible = "fixed-clock";
			#clock-cells = <0>;
			clock-frequency = <500000000>; /* 500MHz Clock half of CPU clock*/
			clock-output-names = "clk_mali";
		};
		clk_pclk: clk_pclk {
			compatible = "fixed-clock";
			#clock-cells = <0>;
			clock-frequency = <74250000>;
			clock-output-names = "clk_pclk";
		};
		rtcclk: rtcclk {
			compatible = "fixed-clock";
			#clock-cells = <0>;
			clock-frequency = <1>; /* 1Hz */
		};
		clk_xin: clk_xin {
			compatible = "fixed-clock";
			#clock-cells = <0>;
			clock-frequency = <200000000>;
			clock-output-names = "clk_xin";
		};
	};

	soc {
		compatible = "simple-bus";
		#address-cells = <2>;
		#size-cells = <2>;
		interrupt-parent = <&gic500>;
		ranges;

		gic500: interrupt-controller@40400000 {
			compatible = "arm,gic-v3";
			#address-cells = <2>;
			#size-cells = <2>;
			ranges;
			#interrupt-cells = <3>;
			interrupt-controller;
			#redistributor-regions = <1>;
			reg = <0x00 0x40400000 0x00 0x10000>,
				  <0x00 0x40500000 0x00 0xC0000>;
			interrupts = <GIC_PPI 9 IRQ_TYPE_LEVEL_HIGH>;
		};

		/* GPIO Controller banks 0 - 7 */
		gpio0: gpio-controller@33000000 {
			compatible = "axiado,ax3000-gpio";
			clocks = <&pclk>;
			gpio-controller;
			#gpio-cells = <2>;
			interrupt-parent = <&gic500>;
			interrupts = <GIC_SPI 183 IRQ_TYPE_LEVEL_HIGH>;
			interrupt-controller;
			reg = <0x00 0x33000000 0x00 0x100>;
			#interrupt-cells = <2>;
			status = "disabled";
		};

		gpio1: gpio-controller@33080000 {
			compatible = "axiado,ax3000-gpio";
			clocks = <&pclk>;
			gpio-controller;
			#gpio-cells = <2>;
			interrupt-parent = <&gic500>;
			interrupts = <GIC_SPI 184 IRQ_TYPE_LEVEL_HIGH>;
			interrupt-controller;
			reg = <0x00 0x33080000 0x00 0x100>;
			#interrupt-cells = <2>;
			status = "disabled";
		};

		gpio2: gpio-controller@33100000 {
			compatible = "axiado,ax3000-gpio";
			clocks = <&pclk>;
			gpio-controller;
			#gpio-cells = <2>;
			interrupt-parent = <&gic500>;
			interrupts = <GIC_SPI 185 IRQ_TYPE_LEVEL_HIGH>;
			interrupt-controller;
			reg = <0x00 0x33100000 0x00 0x100>;
			#interrupt-cells = <2>;
			status = "disabled";
		};

		gpio3: gpio-controller@33180000 {
			compatible = "axiado,ax3000-gpio";
			clocks = <&pclk>;
			gpio-controller;
			#gpio-cells = <2>;
			interrupt-parent = <&gic500>;
			interrupts = <GIC_SPI 186 IRQ_TYPE_LEVEL_HIGH>;
			interrupt-controller;
			reg = <0x00 0x33180000 0x00 0x100>;
			#interrupt-cells = <2>;
			status = "disabled";
		};

		gpio4: gpio-controller@0x33200000 {
			compatible = "axiado,ax3000-gpio";
			clocks = <&pclk>;
			gpio-controller;
			#gpio-cells = <2>;
			interrupt-parent = <&gic500>;
			interrupts = <GIC_SPI 187 IRQ_TYPE_LEVEL_HIGH>;
			interrupt-controller;
			reg = <0x00 0x33200000 0x00 0x100>;
			#interrupt-cells = <2>;
			status = "disabled";
		};

		gpio5: gpio-controller@33280000 {
			compatible = "axiado,ax3000-gpio";
			clocks = <&pclk>;
			gpio-controller;
			#gpio-cells = <2>;
			interrupt-parent = <&gic500>;
			interrupts = <GIC_SPI 188 IRQ_TYPE_LEVEL_HIGH>;
			interrupt-controller;
			reg = <0x00 0x33280000 0x00 0x100>;
			#interrupt-cells = <2>;
			status = "disabled";
		};

		gpio6: gpio-controller@33300000 {
			compatible = "axiado,ax3000-gpio";
			clocks = <&pclk>;
			gpio-controller;
			#gpio-cells = <2>;
			interrupt-parent = <&gic500>;
			interrupts = <GIC_SPI 189 IRQ_TYPE_LEVEL_HIGH>;
			interrupt-controller;
			reg = <0x00 0x33300000 0x00 0x100>;
			#interrupt-cells = <2>;
			status = "disabled";
		};

		gpio7: gpio-controller@33380000 {
			compatible = "axiado,ax3000-gpio";
			clocks = <&pclk>;
			gpio-controller;
			#gpio-cells = <2>;
			interrupt-parent = <&gic500>;
			interrupts = <GIC_SPI 190 IRQ_TYPE_LEVEL_HIGH>;
			interrupt-controller;
			reg = <0x00 0x33380000 0x00 0x100>;
			#interrupt-cells = <2>;
			status = "disabled";
		};

		uart0: serial0@33020000 {
			compatible = "cdns,uart-r1p12";
			interrupt-parent = <&gic500>;
			interrupts = <GIC_SPI 112 IRQ_TYPE_LEVEL_HIGH>;
			reg = <0x00 0x33020000 0x00 0x100>;
			clock-names = "uart_clk", "pclk";
			clocks = <&refclk &pclk>;
			uart-clk = <10000000>;
			status = "disabled";
		};

		uart1: serial1@330A0000 {
			compatible = "cdns,uart-r1p12";
			interrupt-parent = <&gic500>;
			interrupts = <GIC_SPI 113 IRQ_TYPE_LEVEL_HIGH>;
			reg = <0x00 0x330A0000 0x00 0x100>;
			clock-names = "uart_clk", "pclk";
			clocks = <&refclk &pclk>;
			uart-clk = <10000000>;
			status = "disabled";
		};

		uart2: serial2@33120000 {
			compatible = "cdns,uart-r1p12";
			interrupt-parent = <&gic500>;
			interrupts = <GIC_SPI 114 IRQ_TYPE_LEVEL_HIGH>;
			reg = <0x00 0x33120000 0x00 0x100>;
			clock-names = "uart_clk", "pclk";
			clocks = <&refclk &pclk>;
			uart-clk = <10000000>;
			status = "disabled";
		};

		uart3: serial3@33020800 {
			compatible = "cdns,uart-r1p12";
			interrupt-parent = <&gic500>;
			interrupts = <GIC_SPI 170 IRQ_TYPE_LEVEL_HIGH>;
			reg = <0x00 0x33020800 0x00 0x100>;
			clock-names = "uart_clk", "pclk";
			clocks = <&refclk &pclk>;
			uart-clk = <10000000>;
			status = "disabled";
		};

		uart4: serial4@331a0400 {
			compatible = "cdns,uart-r1p12";
			interrupt-parent = <&gic500>;
			interrupts = <GIC_SPI 208 IRQ_TYPE_LEVEL_HIGH>;
			reg = <0x00 0x331a0400 0x00 0x100>;
			clock-names = "uart_clk", "pclk";
			clocks = <&refclk &pclk>;
			uart-clk = <10000000>;
			status = "disabled";
		};

		uart5: serial5@33381D00 {
			compatible = "cdns,uart-r1p12";
			interrupt-parent = <&gic500>;
			interrupts = <GIC_SPI 209 IRQ_TYPE_LEVEL_HIGH>;
			reg = <0x00 0x33381D00 0x00 0x100>;
			clock-names = "uart_clk", "pclk";
			clocks = <&refclk &pclk>;
			uart-clk = <10000000>;
			status = "disabled";
		};

		uart6: serial6@33381E00 {
			compatible = "cdns,uart-r1p12";
			interrupt-parent = <&gic500>;
			interrupts = <GIC_SPI 210 IRQ_TYPE_LEVEL_HIGH>;
			reg = <0x00 0x33381E00 0x00 0x100>;
			clock-names = "uart_clk", "pclk";
			clocks = <&refclk &pclk>;
			uart-clk = <10000000>;
			status = "disabled";
		};

		uart7: serial7@33381F00 {
			compatible = "cdns,uart-r1p12";
			interrupt-parent = <&gic500>;
			interrupts = <GIC_SPI 211 IRQ_TYPE_LEVEL_HIGH>;
			reg = <0x00 0x33381F00 0x00 0x100>;
			clock-names = "uart_clk", "pclk";
			clocks = <&refclk &pclk>;
			uart-clk = <10000000>;
			status = "disabled";
		};

		uart8: serial8@330C0000 {
			compatible = "cdns,uart-r1p12";
			interrupt-parent = <&gic500>;
			interrupts = <GIC_SPI 212 IRQ_TYPE_LEVEL_HIGH>;
			reg = <0x00 0x330C0000 0x00 0x100>;
			clock-names = "uart_clk", "pclk";
			clocks = <&refclk &pclk>;
			uart-clk = <10000000>;
			status = "disabled";
		};

		i2c0: i2c@33000400 {
			compatible = "axiado,ax3000-i2c", "cdns,i2c-r1p14";
			clocks = <&pclk>;
			interrupt-parent = <&gic500>;
			interrupts = <GIC_SPI 76 IRQ_TYPE_LEVEL_HIGH>;
			reg = <0x00 0x33000400 0x00 0x400>;
			#address-cells = <1>;
			#size-cells = <0>;
			status = "disabled";
		};

		i2c1: i2c@33000800 {
			compatible = "axiado,ax3000-i2c", "cdns,i2c-r1p14";
			clocks = <&pclk>;
			interrupt-parent = <&gic500>;
			interrupts = <GIC_SPI 77 IRQ_TYPE_LEVEL_HIGH>;
			reg = <0x00 0x33000800 0x00 0x400>;
			#address-cells = <1>;
			#size-cells = <0>;
			status = "disabled";
		};

		i2c2: i2c@33080400 {
			compatible = "axiado,ax3000-i2c", "cdns,i2c-r1p14";
			clocks = <&pclk>;
			interrupt-parent = <&gic500>;
			interrupts = <GIC_SPI 78 IRQ_TYPE_LEVEL_HIGH>;
			reg = <0x00 0x33080400 0x00 0x400>;
			#address-cells = <1>;
			#size-cells = <0>;
			status = "disabled";
		};

		i2c3: i2c@33080800 {
			compatible = "axiado,ax3000-i2c", "cdns,i2c-r1p14";
			clocks = <&pclk>;
			interrupt-parent = <&gic500>;
			interrupts = <GIC_SPI 79 IRQ_TYPE_LEVEL_HIGH>;
			reg = <0x00 0x33080800 0x00 0x400>;
			#address-cells = <1>;
			#size-cells = <0>;
			status = "disabled";
		};

		i2c4: i2c@33100400 {
			compatible = "axiado,ax3000-i2c", "cdns,i2c-r1p14";
			clocks = <&pclk>;
			interrupt-parent = <&gic500>;
			interrupts = <GIC_SPI 80 IRQ_TYPE_LEVEL_HIGH>;
			reg = <0x00 0x33100400 0x00 0x400>;
			#address-cells = <1>;
			#size-cells = <0>;
			status = "disabled";
		};

		i2c5: i2c@33100800 {
			compatible = "axiado,ax3000-i2c", "cdns,i2c-r1p14";
			clocks = <&pclk>;
			interrupt-parent = <&gic500>;
			interrupts = <GIC_SPI 81 IRQ_TYPE_LEVEL_HIGH>;
			reg = <0x00 0x33100800 0x00 0x400>;
			#address-cells = <1>;
			#size-cells = <0>;
			status = "disabled";
		};

		i3c6: i2c@33180400 {
			compatible = "cdns,i3c-master";
			clocks = <&pclk &sysclk>;
			clock-names = "pclk", "sysclk";
			interrupt-parent = <&gic500>;
			interrupts = <GIC_SPI 82 IRQ_TYPE_LEVEL_HIGH>;
			i2c-scl-hz = <100000>;
			i3c-scl-hz = <400000>;
			reg = <0x00 0x33180400 0x00 0x400>;
			#address-cells = <3>;
			#size-cells = <0>;
			status = "disabled";
		};

		i3c7: i2c@33180800 {
			compatible = "cdns,i3c-master";
			clocks = <&pclk &sysclk>;
			clock-names = "pclk", "sysclk";
			interrupt-parent = <&gic500>;
			interrupts = <GIC_SPI 83 IRQ_TYPE_LEVEL_HIGH>;
			i2c-scl-hz = <100000>;
			i3c-scl-hz = <400000>;
			reg = <0x00 0x33180800 0x00 0x400>;
			#address-cells = <3>;
			#size-cells = <0>;
			status = "disabled";
		};

		i3c8: i2c@33200400 {
			compatible = "cdns,i3c-master";
			clocks = <&pclk &sysclk>;
			clock-names = "pclk", "sysclk";
			interrupt-parent = <&gic500>;
			interrupts = <GIC_SPI 84 IRQ_TYPE_LEVEL_HIGH>;
			i2c-scl-hz = <100000>;
			i3c-scl-hz = <400000>;
			reg = <0x00 0x33200400 0x00 0x400>;
			#address-cells = <3>;
			#size-cells = <0>;
			status = "disabled";
		};

		i3c9: i2c@33200800 {
			compatible = "cdns,i3c-master";
			clocks = <&pclk &sysclk>;
			clock-names = "pclk", "sysclk";
			interrupt-parent = <&gic500>;
			interrupts = <GIC_SPI 85 IRQ_TYPE_LEVEL_HIGH>;
			i2c-scl-hz = <100000>;
			i3c-scl-hz = <400000>;
			reg = <0x00 0x33200800 0x00 0x400>;
			#address-cells = <3>;
			#size-cells = <0>;
			status = "disabled";
		};

		i2c10: i2c@33280400 {
			compatible = "axiado,ax3000-i2c", "cdns,i2c-r1p14";
			clocks = <&pclk>;
			interrupt-parent = <&gic500>;
			interrupts = <GIC_SPI 86 IRQ_TYPE_LEVEL_HIGH>;
			reg = <0x00 0x33280400 0x00 0x400>;
			#address-cells = <1>;
			#size-cells = <0>;
			status = "disabled";
		};

		i2c11: i2c@33280800 {
			compatible = "axiado,ax3000-i2c", "cdns,i2c-r1p14";
			clocks = <&pclk>;
			interrupt-parent = <&gic500>;
			interrupts = <GIC_SPI 87 IRQ_TYPE_LEVEL_HIGH>;
			reg = <0x00 0x33280800 0x00 0x400>;
			#address-cells = <1>;
			#size-cells = <0>;
			status = "disabled";
		};

		i3c12: i2c@33300400 {
			compatible = "cdns,i3c-master";
			clocks = <&pclk &sysclk>;
			clock-names = "pclk", "sysclk";
			interrupt-parent = <&gic500>;
			interrupts = <GIC_SPI 88 IRQ_TYPE_LEVEL_HIGH>;
			i2c-scl-hz = <100000>;
			i3c-scl-hz = <400000>;
			reg = <0x00 0x33300400 0x00 0x400>;
			#address-cells = <3>;
			#size-cells = <0>;
			status = "disabled";
		};

		i3c13: i2c@33300800 {
			compatible = "cdns,i3c-master";
			clocks = <&pclk &sysclk>;
			clock-names = "pclk", "sysclk";
			interrupt-parent = <&gic500>;
			interrupts = <GIC_SPI 89 IRQ_TYPE_LEVEL_HIGH>;
			i2c-scl-hz = <100000>;
			i3c-scl-hz = <400000>;
			reg = <0x00 0x33300800 0x00 0x400>;
			#address-cells = <3>;
			#size-cells = <0>;
			status = "disabled";
		};

		i2c14: i2c@33380400 {
			compatible = "axiado,ax3000-i2c", "cdns,i2c-r1p14";
			clocks = <&pclk>;
			interrupt-parent = <&gic500>;
			interrupts = <GIC_SPI 90 IRQ_TYPE_LEVEL_HIGH>;
			reg = <0x00 0x33380400 0x00 0x400>;
			#address-cells = <1>;
			#size-cells = <0>;
			status = "disabled";
		};

		i2c15: i2c@33380800 {
			compatible = "axiado,ax3000-i2c", "cdns,i2c-r1p14";
			clocks = <&pclk>;
			interrupt-parent = <&gic500>;
			interrupts = <GIC_SPI 91 IRQ_TYPE_LEVEL_HIGH>;
			reg = <0x00 0x33380800 0x00 0x400>;
			#address-cells = <1>;
			#size-cells = <0>;
			status = "disabled";
		};

		i2c16: i2c@33120400 {
			compatible = "axiado,ax3000-i2c", "cdns,i2c-r1p14";
			clocks = <&pclk>;
			interrupt-parent = <&gic500>;
			interrupts = <GIC_SPI 92 IRQ_TYPE_LEVEL_HIGH>;
			reg = <0x00 0x33120400 0x00 0x400>;
			#address-cells = <1>;
			#size-cells = <0>;
			status = "disabled";
		};

		i2c17: i2c@33021400 {
			compatible = "axiado,ax3000-i2c", "cdns,i2c-r1p14";
			clocks = <&pclk>;
			interrupt-parent = <&gic500>;
			interrupts = <GIC_SPI 213 IRQ_TYPE_LEVEL_HIGH>;
			reg = <0x00 0x33021400 0x00 0x400>;
			#address-cells = <1>;
			#size-cells = <0>;
			status = "disabled";
		};

		i2c18: i2c@33021800 {
			compatible = "axiado,ax3000-i2c", "cdns,i2c-r1p14";
			clocks = <&pclk>;
			interrupt-parent = <&gic500>;
			interrupts = <GIC_SPI 214 IRQ_TYPE_LEVEL_HIGH>;
			reg = <0x00 0x33021800 0x00 0x400>;
			#address-cells = <1>;
			#size-cells = <0>;
			status = "disabled";
		};

		i2c19: i2c@330C0400 {
			compatible = "axiado,ax3000-i2c", "cdns,i2c-r1p14";
