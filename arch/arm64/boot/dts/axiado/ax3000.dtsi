/dts-v1/;

#include <dt-bindings/interrupt-controller/irq.h>
#include <dt-bindings/interrupt-controller/arm-gic.h>

/memreserve/ 0x3c0013a0 0x00000008;	/* cpu-release-addr */
/ {
	model = "Axiado AX3000";
	interrupt-parent = <&gic500>;
	#address-cells = <2>;
	#size-cells = <2>;

	cpus {
		#address-cells = <2>;
		#size-cells = <0>;

		cpu0: cpu@0 {
			device_type = "cpu";
			compatible = "arm,cortex-a53";
			reg = <0x0 0x0>;
			enable-method = "spin-table";
			cpu-release-addr = <0x0 0x3c0013a0>;
			d-cache-size = <0x8000>;
			d-cache-line-size = <64>;
			d-cache-sets = <128>;
			i-cache-size = <0x8000>;
			i-cache-line-size = <64>;
			i-cache-sets = <256>;
			next-level-cache = <&l2>;
		};

		cpu1: cpu@1 {
			device_type = "cpu";
			compatible = "arm,cortex-a53";
			reg = <0x0 0x1>;
			enable-method = "spin-table";
			cpu-release-addr = <0x0 0x3c0013a0>;
			d-cache-size = <0x8000>;
			d-cache-line-size = <64>;
			d-cache-sets = <128>;
			i-cache-size = <0x8000>;
			i-cache-line-size = <64>;
			i-cache-sets = <256>;
			next-level-cache = <&l2>;
		};

		cpu2: cpu@2 {
			device_type = "cpu";
			compatible = "arm,cortex-a53";
			reg = <0x0 0x2>;
			enable-method = "spin-table";
			cpu-release-addr = <0x0 0x3c0013a0>;
			d-cache-size = <0x8000>;
			d-cache-line-size = <64>;
			d-cache-sets = <128>;
			i-cache-size = <0x8000>;
			i-cache-line-size = <64>;
			i-cache-sets = <256>;
			next-level-cache = <&l2>;
		};

		cpu3: cpu@3 {
			device_type = "cpu";
			compatible = "arm,cortex-a53";
			reg = <0x0 0x3>;
			enable-method = "spin-table";
			cpu-release-addr = <0x0 0x3c0013a0>;
			d-cache-size = <0x8000>;
			d-cache-line-size = <64>;
			d-cache-sets = <128>;
			i-cache-size = <0x8000>;
			i-cache-line-size = <64>;
			i-cache-sets = <256>;
			next-level-cache = <&l2>;
		};

		l2: l2-cache0 {
			compatible = "cache";
			cache-size = <0x100000>;
			cache-unified;
			cache-line-size = <64>;
			cache-sets = <1024>;
			cache-level = <2>;
		};
	};

	reserved-memory {
		#address-cells = <2>;
		#size-cells = <2>;
		ranges;
		pci_ep_disp: pci_ep_disp@40000000 {
			reg = <0x00 0x40000000 0x00 0x8000000>,
			      <0x00 0x48000000 0x00 0x100000>;
			no-map;
		};
		shared_mem_rsvd_m0: mem_region@4000 {
			compatible = "shared-dma-pool";
			reg = <0x00 0x4000 0x00 0x8000>;
			no-map;
		};
		shared_mem_rsvd_ml0: mem_region@3c000 {
			compatible = "shared-dma-pool";
			reg = <0x00 0x3c000 0x00 0x8000>;
			no-map;
		};
		shared_mem_rsvd_ml1: mem_region@44000 {
			compatible = "shared-dma-pool";
			reg = <0x00 0x44000 0x00 0x8000>;
			no-map;
		};
		shared_mem_rsvd_ml2: mem_region@4c000 {
			compatible = "shared-dma-pool";
			reg = <0x00 0x4c000 0x00 0x8000>;
			no-map;
		};
		shared_mem_rsvd_ml3: mem_region@54000 {
			compatible = "shared-dma-pool";
			reg = <0x00 0x54000 0x00 0x8000>;
			no-map;
		};
	};

	display-subsystem {
		compatible = "axiado,display-subsystem";
	};

	clocks {
		clk_xin: clock-200000000 {
			compatible = "fixed-clock";
			#clock-cells = <0>;
			clock-frequency = <200000000>;
			clock-output-names = "clk_xin";
		};

		refclk: clock-125000000 {
			compatible = "fixed-clock";
			#clock-cells = <0>;
			clock-frequency = <125000000>;
		};

		spi_clk: spi_clk {
			compatible = "fixed-clock";
			#clock-cells = <0>;
			clock-frequency = <25000000>;
		};

		apb_pclk: apb_pclk {
			compatible = "fixed-clock";
			#clock-cells = <0>;
			clock-frequency = <25000000>;
		};

		clk_disp: clock-500000000 {
			compatible = "fixed-clock";
			#clock-cells = <0>;
			clock-frequency = <500000000>; /* 500MHz Clock half of CPU clock*/
			clock-output-names = "clk_disp";
		};

		clk_pclk: clock-74250000 {
			compatible = "fixed-clock";
			#clock-cells = <0>;
			clock-frequency = <74250000>;
			clock-output-names = "clk_pclk";
		};
	};

	soc {
		compatible = "simple-bus";
		ranges;
		#address-cells = <2>;
		#size-cells = <2>;
		interrupt-parent = <&gic500>;

		gic500: interrupt-controller@80300000 {
			compatible = "arm,gic-v3";
			reg = <0x00 0x80300000 0x00 0x10000>,
			      <0x00 0x80380000 0x00 0x80000>;
			ranges;
			#interrupt-cells = <3>;
			#address-cells = <2>;
			#size-cells = <2>;
			interrupt-controller;
			#redistributor-regions = <1>;
			interrupts = <GIC_PPI 9 IRQ_TYPE_LEVEL_HIGH>;
		};
		ipc0: m0-ipc@4000 {
			compatible = "axiado,ax-ipc";
			#interrupt-cells = <1>;
			reg = <0x00 0x4000 0x00 0x8000>,    /* Shared mem info */
			<0x0 0x88014120 0x0 0x4>,       /* TX intr mem info */
			<0x0 0x88014154 0x0 0x4>,       /* RX intr mem info */
			<0x0 0x02A00000 0x0 0x100000>,  /* Data buffers for A53->M0*/
			<0x0 0x80620804 0x0 0x4>,       /* scratchpad1 register, for boot status */
			<0x0 0x01500000 0x0 0x4>;       /* scratchpad region, for mmc partition */
			memory-region = <&shared_mem_rsvd_m0>;
			interrupts = <GIC_SPI 171 IRQ_TYPE_LEVEL_HIGH>;
			LABEL = "M0";
			interrupt-parent = <&gic500>;
			status = "okay";
		};
		ipc1: ml0-ipc@3C000 {
			compatible = "axiado,ax-ipc";
			#interrupt-cells = <1>;
			reg = <0x00 0x3C000 0x00 0x8000>,   /* Shared mem info */
			<0x0 0x88014140 0x0 0x4>,       /* TX intr mem info */
			<0x0 0x88000070 0x0 0x4>,       /* RX intr mem info */
			<0x0 0x04800000 0x0 0x100000>;  /* Data buffers for A53->ML0 */
			memory-region = <&shared_mem_rsvd_ml0>;
			interrupts = <GIC_SPI 195 IRQ_TYPE_LEVEL_HIGH>;
			LABEL = "ML0";
			interrupt-parent = <&gic500>;
			status = "okay";
		};
		ipc2: ml1-ipc@44000 {
			compatible = "axiado,ax-ipc";
			#interrupt-cells = <1>;
			reg = <0x00 0x44000 0x00 0x8000>,   /* Shared mem info */
			<0x0 0x88014144 0x0 0x4>,       /* TX intr mem info */
			<0x0 0x88002070 0x0 0x4>,       /* RX intr mem info */
			<0x0 0x11000000 0x0 0x100000>;  /* Data buffers for A53->ML1*/
			memory-region = <&shared_mem_rsvd_ml1>;
			interrupts = <GIC_SPI 196 IRQ_TYPE_LEVEL_HIGH>;
			LABEL = "ML1";
			interrupt-parent = <&gic500>;
			status = "okay";
		};
		ipc3: ml2-ipc@4C000 {
			compatible = "axiado,ax-ipc";
			#interrupt-cells = <1>;
			reg = <0x00 0x4C000 0x00 0x8000>,   /* Shared mem info */
			<0x0 0x88014148 0x0 0x4>,       /* TX intr mem info */
			<0x0 0x88004070 0x0 0x4>,       /* RX intr mem info */
			<0x0 0x1D800000 0x0 0x100000>;  /* Data buffers for A53->ML2*/
			memory-region = <&shared_mem_rsvd_ml2>;
			interrupts = <GIC_SPI 197 IRQ_TYPE_LEVEL_HIGH>;
			LABEL = "ML2";
			interrupt-parent = <&gic500>;
			status = "okay";
		};
		ipc4: ml3-ipc@54000 {
			compatible = "axiado,ax-ipc";
			#interrupt-cells = <1>;
			reg = <0x00 0x54000 0x00 0x8000>,   /* Shared mem info */
			<0x0 0x8801414c 0x0 0x4>,       /* TX intr mem info */
			<0x0 0x88006070 0x0 0x4>,       /* RX intr mem info */
			<0x0 0x2A000000 0x0 0x100000>;  /* Data buffers for A53->ML3*/
			memory-region = <&shared_mem_rsvd_ml3>;
			interrupts = <GIC_SPI 198 IRQ_TYPE_LEVEL_HIGH>;
			LABEL = "ML3";
			interrupt-parent = <&gic500>;
			status = "okay";
		};
		/* GPIO Controller banks 0 - 7 */
		gpio0: gpio-controller@80500000 {
			compatible = "axiado,ax3000-gpio", "cdns,gpio-r1p02";
			reg = <0x00 0x80500000 0x00 0x400>;
			clocks = <&refclk>;
			interrupt-parent = <&gic500>;
			interrupts = <GIC_SPI 183 IRQ_TYPE_LEVEL_HIGH>;
			gpio-controller;
			#gpio-cells = <2>;
			interrupt-controller;
			#interrupt-cells = <2>;
			status = "disabled";
		};

		gpio1: gpio-controller@80580000 {
			compatible = "axiado,ax3000-gpio", "cdns,gpio-r1p02";
			reg = <0x00 0x80580000 0x00 0x400>;
			clocks = <&refclk>;
			interrupt-parent = <&gic500>;
			interrupts = <GIC_SPI 184 IRQ_TYPE_LEVEL_HIGH>;
			gpio-controller;
			#gpio-cells = <2>;
			interrupt-controller;
			#interrupt-cells = <2>;
			status = "disabled";
		};

		gpio2: gpio-controller@80600000 {
			compatible = "axiado,ax3000-gpio", "cdns,gpio-r1p02";
			reg = <0x00 0x80600000 0x00 0x400>;
			clocks = <&refclk>;
			interrupt-parent = <&gic500>;
			interrupts = <GIC_SPI 185 IRQ_TYPE_LEVEL_HIGH>;
			gpio-controller;
			#gpio-cells = <2>;
			interrupt-controller;
			#interrupt-cells = <2>;
			status = "disabled";
		};

		gpio3: gpio-controller@80680000 {
			compatible = "axiado,ax3000-gpio", "cdns,gpio-r1p02";
			reg = <0x00 0x80680000 0x00 0x400>;
			clocks = <&refclk>;
			interrupt-parent = <&gic500>;
			interrupts = <GIC_SPI 186 IRQ_TYPE_LEVEL_HIGH>;
			gpio-controller;
			#gpio-cells = <2>;
			interrupt-controller;
			#interrupt-cells = <2>;
			status = "disabled";
		};

		gpio4: gpio-controller@80700000 {
			compatible = "axiado,ax3000-gpio", "cdns,gpio-r1p02";
			reg = <0x00 0x80700000 0x00 0x400>;
			clocks = <&refclk>;
			interrupt-parent = <&gic500>;
			interrupts = <GIC_SPI 187 IRQ_TYPE_LEVEL_HIGH>;
			gpio-controller;
			#gpio-cells = <2>;
			interrupt-controller;
			#interrupt-cells = <2>;
			status = "disabled";
		};

		gpio5: gpio-controller@80780000 {
			compatible = "axiado,ax3000-gpio", "cdns,gpio-r1p02";
			reg = <0x00 0x80780000 0x00 0x400>;
			clocks = <&refclk>;
			interrupt-parent = <&gic500>;
			interrupts = <GIC_SPI 188 IRQ_TYPE_LEVEL_HIGH>;
			gpio-controller;
			#gpio-cells = <2>;
			interrupt-controller;
			#interrupt-cells = <2>;
			status = "disabled";
		};

		gpio6: gpio-controller@80800000 {
			compatible = "axiado,ax3000-gpio", "cdns,gpio-r1p02";
			reg = <0x00 0x80800000 0x00 0x400>;
			clocks = <&refclk>;
			interrupt-parent = <&gic500>;
			interrupts = <GIC_SPI 189 IRQ_TYPE_LEVEL_HIGH>;
			gpio-controller;
			#gpio-cells = <2>;
			interrupt-controller;
			#interrupt-cells = <2>;
			status = "disabled";
		};

		gpio7: gpio-controller@80880000 {
			compatible = "axiado,ax3000-gpio", "cdns,gpio-r1p02";
			reg = <0x00 0x80880000 0x00 0x400>;
			clocks = <&refclk>;
			interrupt-parent = <&gic500>;
			interrupts = <GIC_SPI 190 IRQ_TYPE_LEVEL_HIGH>;
			gpio-controller;
			#gpio-cells = <2>;
			interrupt-controller;
			#interrupt-cells = <2>;
			status = "disabled";
		};

		spi0: spi@80510000 {
			compatible = "axiado,ax3000-spi";
			reg = <0x00 0x80510000 0x00 0x1000>;
			clock-names = "ref", "pclk";
			clocks = <&spi_clk>, <&apb_pclk>;
			interrupt-parent = <&gic500>;
			interrupts = <GIC_SPI 115 IRQ_TYPE_LEVEL_HIGH>;
			num-cs = <1>;
			status = "disabled";
		};

		spi1: spi@80590000 {
			compatible = "axiado,ax3000-spi";
			reg = <0x00 0x80590000 0x00 0x1000>;
			clock-names = "ref", "pclk";
			clocks = <&spi_clk>, <&apb_pclk>;
			interrupt-parent = <&gic500>;
			interrupts = <GIC_SPI 116 IRQ_TYPE_LEVEL_HIGH>;
			num-cs = <1>;
			status = "disabled";
		};

		spi2: spi@80610000 {
			compatible = "axiado,ax3000-spi";
			reg = <0x00 0x80610000 0x00 0x1000>;
			clock-names = "ref", "pclk";
			clocks = <&spi_clk>, <&apb_pclk>;
			interrupt-parent = <&gic500>;
			interrupts = <GIC_SPI 117 IRQ_TYPE_LEVEL_HIGH>;
			num-cs = <1>;
			#address-cells = <1>;
			#size-cells = <0>;
			status = "disabled";

			/* MFD parent device representing the Solang peripheral */
			axiado_mfd: spi-bridge@0 {
				compatible = "axiado,ax3000-spi-bridge", "axiado,spi-bridge";
				/* Current spi-axiado drv ignores the value from the device tree */
				spi-max-frequency = <25000000>;
				reg = <0x0>; /* Chip select 0 */
				#address-cells = <1>;
				#size-cells = <1>;
				interrupt-controller;
				#interrupt-cells = <1>;
				interrupt-names = "mfd-shared";
				interrupt-parent = <&gpio6>;
				/* GPIO_212 LTPI-I2C Interrupt */
				interrupts = <20 IRQ_TYPE_LEVEL_HIGH>;
				status = "disabled";
				mfd_i2c0: i2c-ssif@0 {
					compatible = "axiado,xps-iic-slave";
					#address-cells = <1>;
					#size-cells = <0>;
					reg = <0x0 0x800>;
					clocks = <&refclk &clk_xin>;
					#interrupt-cells = <2>;
					interrupt-parent = <&gpio6>;
					interrupts = <11 IRQ_TYPE_LEVEL_HIGH>; /* GPIO_203 I2C slave interrupt */
					clock-frequency = <100000>;
					/* Axiado-specific IRQ thread tuning */
					axiado,irq-rt-priority = <90>; /* 1..99, SCHED_FIFO */
					axiado,irq-cpu = <2>; /* pin threaded IRQ to CPU2 */
					status = "disabled";
					ssif-bmc@10 {
						compatible = "ssif-bmc";
						reg = <0x10>;
						status = "disabled";
					};
				};
				mfd_i2c0_cdns: i2c@0 {
					compatible = "axiado,ax3000-i2c";
					#address-cells = <1>;
					#size-cells = <0>;
					reg = <0x0 0x800>;
					clocks = <&refclk &clk_xin>;
					#interrupt-cells = <2>;
					interrupt-parent = <&gpio6>;
					/* GPIO_203 I2C slave interrupt */
					interrupts = <11 IRQ_TYPE_LEVEL_HIGH>;
					clock-frequency = <100000>;
					status = "disabled";
				};
				/* Child node for the second Cadence I2C IP */
				mfd_i2c1: i2c@800 {
					compatible = "axiado,ax3000-i2c";
					reg = <0x0800 0x400>; /* i2c_1_base_addr and size */
					#interrupt-cells = <2>;
					interrupt-parent = <&gpio6>;
					/* Direct GPIO 204 IRQ */
					interrupts = <12 IRQ_TYPE_LEVEL_HIGH>;
					clocks = <&refclk &clk_xin>;
					clock-frequency = <100000>;
					status = "disabled";
				};
				mfd_i2c2: i2c@c00 {
					compatible = "axiado,ax3000-i2c";
					reg = <0x0c00 0x400>; /* i2c_2_base_addr and size */
					#interrupt-cells = <2>;
					interrupt-parent = <&gpio6>;
					/* Direct GPIO 205 IRQ */
					interrupts = <13 IRQ_TYPE_LEVEL_HIGH>;
					clocks = <&refclk &clk_xin>;
					clock-frequency = <100000>;
					status = "disabled";
				};
				mfd_i2c3: i2c@1000 {
					compatible = "axiado,ax3000-i2c";
					reg = <0x1000 0x400>; /* i2c_3_base_addr and size */
					#interrupt-cells = <2>;
					interrupt-parent = <&gpio6>;
					/* Direct GPIO 206 IRQ */
					interrupts = <14 IRQ_TYPE_LEVEL_HIGH>;
					clocks = <&refclk &clk_xin>;
					clock-frequency = <100000>;
					status = "disabled";
				};
				mfd_i2c4: i2c@1400 {
					compatible = "axiado,ax3000-i2c";
					reg = <0x1400 0x400>; /* i2c_4_base_addr and size */
					#interrupt-cells = <2>;
					interrupt-parent = <&gpio6>;
					/* Direct GPIO 207 IRQ */
					interrupts = <15 IRQ_TYPE_LEVEL_HIGH>;
					clocks = <&refclk &clk_xin>;
					clock-frequency = <100000>;
					status = "disabled";
				};
				mfd_i2c5: i2c@1800 {
					compatible = "axiado,ax3000-i2c";
					reg = <0x1800 0x400>; /* i2c_5_base_addr and size */
					#interrupt-cells = <2>;
					interrupt-parent = <&gpio6>;
					/* Direct GPIO 208 IRQ */
					interrupts = <16 IRQ_TYPE_LEVEL_HIGH>;
					clocks = <&refclk &clk_xin>;
					clock-frequency = <100000>;
					status = "disabled";
				};
				mfd_i2c6: i2c@1c00 {
					compatible = "axiado,ax3000-i2c";
					reg = <0x1c00 0x400>; /* i2c_6_base_addr and size */
					#interrupt-cells = <2>;
					interrupt-parent = <&gpio6>;
					/* Direct GPIO 217 IRQ */
					interrupts = <25 IRQ_TYPE_LEVEL_HIGH>;
					clocks = <&refclk &clk_xin>;
					clock-frequency = <100000>;
					status = "disabled";
				};
				mfd_i2c7: i2c@2000 {
					compatible = "axiado,ax3000-i2c";
					reg = <0x2000 0x400>; /* i2c_7_base_addr and size */
					#interrupt-cells = <2>;
					interrupt-parent = <&gpio6>;
					/* Direct GPIO 219 IRQ */
					interrupts = <27 IRQ_TYPE_LEVEL_HIGH>;
					clocks = <&refclk &clk_xin>;
					clock-frequency = <100000>;
					status = "disabled";
				};
				mfd_i2c8: i2c@2400 {
					compatible = "axiado,ax3000-i2c";
					reg = <0x2400 0x400>; /* i2c_8_base_addr and size */
					#interrupt-cells = <2>;
					interrupt-parent = <&gpio6>;
					/* Direct GPIO 220 IRQ */
					interrupts = <28 IRQ_TYPE_LEVEL_HIGH>;
					clocks = <&refclk &clk_xin>;
					clock-frequency = <100000>;
					status = "disabled";
				};
				mfd_i2c9: i2c@2800 {
					compatible = "axiado,ax3000-i2c";
					reg = <0x2800 0x400>; /* i2c_9_base_addr and size */
					#interrupt-cells = <2>;
					interrupt-parent = <&gpio6>;
					/* Direct GPIO 221 IRQ */
					interrupts = <29 IRQ_TYPE_LEVEL_HIGH>;
					clocks = <&refclk &clk_xin>;
					clock-frequency = <100000>;
					status = "disabled";
				};
				mfd_i2c10: i2c@2c00 {
					compatible = "axiado,ax3000-i2c";
					reg = <0x2c00 0x400>; /* i2c_10_base_addr and size */
					#interrupt-cells = <2>;
					interrupt-parent = <&gpio6>;
					/* Direct GPIO 222 IRQ */
					interrupts = <30 IRQ_TYPE_LEVEL_HIGH>;
					clocks = <&refclk &clk_xin>;
					clock-frequency = <100000>;
					status = "disabled";
				};
				mfd_i2c11: i2c@3000 {
					compatible = "axiado,ax3000-i2c";
					reg = <0x3000 0x400>; /* i2c_11_base_addr and size */
					#interrupt-cells = <2>;
					interrupt-parent = <&gpio7>;
					/* Direct GPIO 245 IRQ */
					interrupts = <21 IRQ_TYPE_LEVEL_HIGH>;
					clocks = <&refclk &clk_xin>;
					clock-frequency = <100000>;
					status = "disabled";
				};
				mfd_i2c12: i2c@3400 {
					compatible = "axiado,ax3000-i2c";
					reg = <0x3400 0x400>; /* i2c_12_base_addr and size */
					#interrupt-cells = <2>;
					interrupt-parent = <&gpio7>;
					/* Direct GPIO 237 IRQ */
					interrupts = <13 IRQ_TYPE_LEVEL_HIGH>;
					clocks = <&refclk &clk_xin>;
					clock-frequency = <100000>;
					status = "disabled";
				};
				mfd_i2c13: i2c@3800 {
					compatible = "axiado,ax3000-i2c";
					reg = <0x3800 0x400>; /* i2c_13_base_addr and size */
					#interrupt-cells = <2>;
					interrupt-parent = <&gpio7>;
					/* Direct GPIO 238 IRQ */
					interrupts = <14 IRQ_TYPE_LEVEL_HIGH>;
					clocks = <&refclk &clk_xin>;
					clock-frequency = <100000>;
					status = "disabled";
				};
				mfd_i2c14: i2c@3c00 {
					compatible = "axiado,ax3000-i2c";
					reg = <0x3c00 0x400>; /* i2c_14_base_addr and size */
					#interrupt-cells = <2>;
					interrupt-parent = <&gpio7>;
					/* Direct GPIO 239 IRQ */
					interrupts = <15 IRQ_TYPE_LEVEL_HIGH>;
					clocks = <&refclk &clk_xin>;
					clock-frequency = <100000>;
					status = "disabled";
				};
				mfd_i2c15: i2c@4000 {
					compatible = "axiado,ax3000-i2c";
					reg = <0x4000 0x400>; /* i2c_15_base_addr and size */
					#interrupt-cells = <2>;
					interrupt-parent = <&gpio7>;
					/* Direct GPIO 240 IRQ */
					interrupts = <16 IRQ_TYPE_LEVEL_HIGH>;
					clocks = <&refclk &clk_xin>;
					clock-frequency = <100000>;
					status = "disabled";
				};
				mfd_i2c16: i2c@4400 {
					compatible = "axiado,ax3000-i2c";
					reg = <0x4400 0x400>; /* i2c_16_base_addr and size */
					#interrupt-cells = <2>;
					interrupt-parent = <&gpio7>;
					/* Direct GPIO 241 IRQ */
					interrupts = <17 IRQ_TYPE_LEVEL_HIGH>;
					clocks = <&refclk &clk_xin>;
					clock-frequency = <100000>;
					status = "disabled";
				};
				ltpi_i2c17: i2c@4800 {
					compatible = "axiado,ax3000-i2c";
					reg = <0x4800 0x400>; /* i2c_14_base_addr and size */
					interrupt-parent = <&axiado_mfd>;
					#interrupt-cells = <1>;
					interrupts = <17>;
					clocks = <&refclk &clk_xin>;
					clock-frequency = <100000>;
					status = "disabled";
				};
				ltpi_i2c18: i2c@4c00 {
					compatible = "axiado,ax3000-i2c";
					reg = <0x4c00 0x400>; /* i2c_18_base_addr and size */
					interrupt-controller;
					#interrupt-cells = <1>;
					interrupts = <18>;
					clocks = <&refclk &clk_xin>;
					clock-frequency = <100000>;
					status = "disabled";
				};
				ltpi_i2c19: i2c@5000 {
					compatible = "axiado,ax3000-i2c";
					reg = <0x5000 0x400>; /* i2c_19_base_addr and size */
					interrupt-controller;
					#interrupt-cells = <1>;
					interrupts = <19>;
					clocks = <&refclk &clk_xin>;
					clock-frequency = <100000>;
					status = "disabled";
				};
				ltpi_i2c20: i2c@5400 {
					compatible = "axiado,ax3000-i2c";
					reg = <0x5400 0x400>; /* i2c_20 and size */
					interrupt-controller;
					#interrupt-cells = <1>;
					interrupts = <20>;
					clocks = <&refclk &clk_xin>;
					clock-frequency = <100000>;
					status = "disabled";
				};
				ltpi_i2c21: i2c@5800 {
					compatible = "axiado,ax3000-i2c";
					reg = <0x5800 0x400>; /* i2c_21 and size */
					interrupt-controller;
					#interrupt-cells = <1>;
					interrupts = <21>;
					clocks = <&refclk &clk_xin>;
					clock-frequency = <100000>;
					status = "disabled";
				};
				ltpi_i2c22: i2c@5c00 {
					compatible = "axiado,ax3000-i2c";
					reg = <0x5c00 0x400>; /* i2c_22 and size */
					interrupt-controller;
					#interrupt-cells = <1>;
					interrupts = <22>;
					clocks = <&refclk &clk_xin>;
					clock-frequency = <100000>;
					status = "disabled";
				};
				mfd_sgpio0: sgpio@a000 {
					compatible = "axiado,sgpio";
					reg = <0xa000 0x800>;
					gpio-controller;
					#gpio-cells = <2>;
					interrupt-parent = <&gpio6>;
					/* GPIO_209 SGPIO Interrupt */
					interrupts = <17 IRQ_TYPE_LEVEL_HIGH>;
					/* Design variants 128 bit or 512 bit */
					design-variant = <128>;
					/* Supports maximum of 128 pins */
					ngpios = <128>;
					/* SGPIO Clock frequency 12 MHz */
					bus-frequency = <12000000>;
					apb-frequency = <100000000>;
					dout-init = <0x00000000 0x00000000 0x00000000 0x00000000>;
					status = "disabled";
				};
				mfd_ltpi0: ltpi@8000 {
					compatible = "axiado,ltpi";
					/* Base offset for regmap */
					reg = <0x8000 0x2000>;
					gpio-controller;
					#gpio-cells = <2>;
					interrupt-parent = <&gpio6>;
					/* GPIO_210 SGPIO Interrupt */
					interrupts = <18 IRQ_TYPE_LEVEL_HIGH>;
					interrupt-controller;
					#interrupt-cells = <2>;
					/* Supports maximum of 128 pins */
					ngpios = <128>;
					dout-init = <0x00000000 0x00000000 0x00000000 0x00000000>;
					status = "disabled";
				};
				mfd_espi: espi@c000 {
					compatible = "axiado,ax3000-espi-regmap";
					reg = <0xc000 0x1000>,
						<0xd000 0x1000>,
						<0xe000 0x1000>;
					reg-names = "espi-core", "espi-perif", "espi-atu";
					interrupt-parent = <&gpio6>;
					interrupts = <19 IRQ_TYPE_LEVEL_HIGH>,   /* GPIO_211 eSPI core */
						   <23 IRQ_TYPE_LEVEL_HIGH>;   /* GPIO_215 external logic */
					interrupt-names = "espi-core-intr", "ext-logic-intr";
					interrupt-controller;
					#interrupt-cells = <1>;
					#address-cells = <1>;
					#size-cells = <1>;
					status = "disabled";

					espi_kcs0: espi-kcs@0 {
						compatible = "axiado,ax3000-kcs-bmc";
						reg = <0x0 0x10>;
						interrupts = <0>; /* Virtual IRQ: bit 0 in external logic ISR */
						interrupt-parent = <&mfd_espi>;
						channel-index = <0>;
						io-addr = <0xCA2>; /* IPMI 2.0: 0xCA2(data) + 0xCA3 (status) */
						host-status-offset = <0x1>; /* 1-byte offset per IPMI 2.0 spec */
						status = "disabled";
					};

					espi_snoop: espi-snoop@C0 {
						compatible = "axiado,ax3000-espi-snoop";
						reg = <0xC0 0x10>;
						interrupts = <13>;
						interrupt-parent = <&mfd_espi>;
						io-addr = <0x80>;
						status = "disabled";
					};

					espi_uart0: espi-uart@40 {
						compatible = "axiado,ax3000-espi-uart";
						reg = <0x40 0x02>;
						interrupts = <5>; /* Virtual IRQ: bit 5 */
						interrupt-parent = <&mfd_espi>;
						clock-names = "uart_clk", "pclk";
						clocks = <&refclk &refclk>;
						channel-index = <0>;
						io-addr = <0x3F8>;
						fifo-size = <16>;
						cpu-fifo-size = <64>;
						status = "disabled";
					};
				};
			};
		};

