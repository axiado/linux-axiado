			reg = <0x00 0x80801400 0x00 0x400>;
			pwms = <&pwm12 0 400>;
			status = "disabled";
		};

		fan13: pwm-fan@80801800 {
			compatible = "axiado,ax3000-pwm-fan";
			interrupt-parent = <&gic500>;
