			reg = <0x00 0x80801800 0x00 0x400>;
			pwms = <&pwm13 0 400>;
			status = "disabled";
		};

		fan14: pwm-fan@80881400 {
			compatible = "axiado,ax3000-pwm-fan";
			interrupt-parent = <&gic500>;
			interrupts = <GIC_SPI 164 IRQ_TYPE_LEVEL_HIGH>;
			reg = <0x00 0x80881400 0x00 0x400>;
			pwms = <&pwm14 0 400>;
			status = "disabled";
		};

		fan15: pwm-fan@80881800 {
			compatible = "axiado,ax3000-pwm-fan";
			interrupt-parent = <&gic500>;
			interrupts = <GIC_SPI 165 IRQ_TYPE_LEVEL_HIGH>;
			reg = <0x00 0x80881800 0x00 0x400>;
			pwms = <&pwm15 0 400>;
			status = "disabled";
		};

		saradc: saradc@806A0000 {
			compatible = "axiado,ax3000-saradc";
			reg = <0x00 0x806A0000 0x00 0x400>;
			interrupt-parent = <&gic500>;
			interrupts = <GIC_SPI 166 IRQ_TYPE_LEVEL_HIGH>;
			clocks = <&refclk>;
			clock-names = "refclk";
			#io-channel-cells = <1>;
			status = "disabled";
		};

		pcie_x1: pcie@85200000 {
			compatible = "axiado,ax3000-pcie";
			status = "disabled";
			device_type = "pci";
			device_role = "vga"; /* VGA EP */
			reg = <0 0x85200000 0 0x1000>, /* CSR reg */
			      <0 0x85300000 0 0x4000>, /* PHY reg */
			      <0 0x85202000 0 0x1000>, /* CFG space */
			      <0 0x85280000 0 0x80000>, /* MBX reg */
			      <0 0x80702400 0 0x100>, /* IOCTL reg */
			      <0 0x85240000 0 0x1000>; /* EXT reg */
			reg-names = "csr", "phy", "cfg", "mbx", "ioctl", "ext";
			#address-cells = <3>;
			#size-cells = <2>;
			interrupts = <GIC_SPI 33 IRQ_TYPE_LEVEL_HIGH>; /* MSI interrupt */
			interrupt-names = "msi";
			interrupt-map-mask = <0 0 0 7>;
			interrupt-map = <0 0 0 1 &gic500 0>, /* int_a */
					<0 0 0 2 &gic500 1>, /* int_b */
					<0 0 0 3 &gic500 2>, /* int_c */
					<0 0 0 4 &gic500 3>; /* int_d */
			num-lanes = <1>;
			clocks = <&clk_pclk> ;
			clock-names = "clk_pclk";
			bus-range = <0x00 0xff>;
			ranges = <0x83000000 0x3 0xE0000000 0x3 0xE0000000 0x0 0x400000>,
				 /* 4M - Port0 Config */
				 <0x82000000 0x0 0x90000000 0x0 0x90000000 0x0 0x8000000>,
				 /* 128M - prefetchable */
				 <0xc2000000 0x0 0x98000000 0x0 0x98000000 0x0 0x100000>;
				 /* 1M - non-prefetchable */

			pci0: pci@1,0 {
				device_type = "pci";
				assigned-addresses = <0x83000800 0x3 0xE0000000 0 0x400000>;
				reg = <0x00800 0 0 0 0>;
				#address-cells = <3>;
				#size-cells = <2>;
				ranges;
			};
		};

		pcie_x2: pcie@85000000 {
			compatible = "axiado,ax3000-pcie";
			status = "disabled";
			device_type = "pci";
			device_role = "host"; /* Host Bridge */
			reg = <0 0x85000000 0 0x1000>, /* CSR reg */
			      <0 0x85100000 0 0x4000>, /* PHY reg */
			      <0 0x85002000 0 0x4000>, /* CFG space */
			      <0 0x85080000 0 0x80000>, /* MBX reg */
			      <0 0x80702400 0 0x100>, /* IOCTL reg */
			      <0 0x85040000 0 0x1000>; /* EXT reg */
			reg-names = "csr", "phy", "cfg", "mbx", "ioctl","ext";
			num-lanes = <2>;
			#address-cells = <3>;
			#size-cells = <2>;
			interrupts = <GIC_SPI 61 IRQ_TYPE_LEVEL_HIGH>; /* MSI interrupt */
			interrupt-names = "msi";
			interrupt-map-mask = <0 0 0 7>;
			interrupt-map = <0 0 0 1 &gic500 0>,
					<0 0 0 2 &gic500 1>,
					<0 0 0 3 &gic500 2>,
					<0 0 0 4 &gic500 3>;
			clocks = <&clk_pclk> ;
			clock-names = "clk_pclk";
			bus-range = <0x00 0xff>;
			ranges = <0x83000000 0x2 0xE0000000 0x2 0xE0000000 0x0 0x400000>,
				 <0xc2000000 0x0 0x99000000 0x0 0x99000000 0x0 0x100000>,
				 <0x82000000 0x0 0xa0000000 0x0 0xa0000000 0x0 0x10000000>;

			pci1: pci@1,0 {
				device_type = "pci";
				assigned-addresses = <0x83000800 0x2 0xE0000000 0 0x400000>;
				reg = <0x00800 0 0 0 0>;
				#address-cells = <3>;
				#size-cells = <2>;
				ranges;
			};
		};

		mctp0: mctp@0 {
			compatible = "axiado,ax3000-mctp";
			reg = <0x0 0x802E0000 0x00 0x20000>;
			reg-names = "ocm-base";
			/* For determining A0, B0 ... etc
			 * Encodes whether this is EP or RC as well.
			 * For EPs, bit 8 is set to 0x1.
			 */
			axrc-version = <0x001>;
			/* for axrc-version == 1, this indicates
			 * Which RC to bind to for VDM generation
			 * <2> -> X2, <1> -> X1
			 */
			axrc-vdm-id = <2>;
			pcie-phandle = <&pcie_x2>;
			isolated-cpu = <3>;
			status = "disabled";
		};

		video: video {
			compatible = "axiado,ax3000-video";
			memory-region = <&pci_ep_disp>;
		};

		disp_ctrl: disp_ctrl@80c00000 {
			compatible = "axiado,drm-db9000";
			reg = <0x0 0x80C00000 0x0 0x1000>;
			memory-region = <&pci_ep_disp>;
			interrupts = <GIC_SPI 14 IRQ_TYPE_LEVEL_HIGH>;
			clocks = <&clk_disp &clk_pclk> ;
			clock-names = "clk_disp", "clk_pclk";
			bits-per-pixel = <32>;
			bus-width = <24>;
			paddr-disp = <0x40000000>;
			status = "disabled";

			disp_out: port {
				#address-cells = <1>;
				#size-cells = <0>;

				disp_out_hdmi: endpoint@0 {
					reg = <0>;
					remote-endpoint = <&hdmi_in_disp>;
				};
			};
		};

		hdmi: hdmi@80C11000 {
			compatible = "axiado,ax3000-hdmi";
			reg = <0x00 0x80C11000 0x00 0x4000>;
			memory-region = <&pci_ep_disp>;
			interrupts = <GIC_SPI 16 IRQ_TYPE_LEVEL_HIGH>;
			clocks =  <&clk_disp>, <&clk_pclk>;
			clock-names = "clk_disp", "clk_pclk";
			#address-cells = <1>;
			#size-cells = <0>;
			status = "disabled";

			hdmi_in: port@0 {
				#address-cells = <1>;
				#size-cells = <0>;

				hdmi_in_disp: endpoint@0 {
					reg = <0>;
					remote-endpoint = <&disp_out_hdmi>;
				};
			};
		};

		/* HCP (Header and Crypto Processing Engine) */
		hcp: hcp@83000000 {
			compatible = "axiado,ax3000-hcp";
			#address-cells = <1>;
			#size-cells = <0>;
			/*
			 * All memory regions for the HCP subsystem:
			 * - EIP-197 crypto engine
			 * - SHIM registers
			 * - PHY CSR
			 */
			reg = <0x0 0x83000000 0x0 0x100000>,  /* EIP-197 (1MB) */
			      <0x0 0x83100000 0x0 0x4000>,    /* SHIM regs (16KB) */
			      <0x0 0x87000000 0x0 0x50000>;   /* PHY CSR (320KB) */
			reg-names = "eip197", "shim", "phy-csr";
			/*
			 * All interrupts for HCP:
			 * IRQ 0: EIP-197 crypto
			 * IRQ 1-4: Rings 0-3
			 * IRQ 5-9: MACs 0-4
			 */
			interrupt-parent = <&gic500>;
			interrupts = <GIC_SPI 0 IRQ_TYPE_LEVEL_HIGH>,  /* EIP-197 */
			             <GIC_SPI 1 IRQ_TYPE_LEVEL_HIGH>,   /* Ring 0 */
			             <GIC_SPI 2 IRQ_TYPE_LEVEL_HIGH>,   /* Ring 1 */
			             <GIC_SPI 3 IRQ_TYPE_LEVEL_HIGH>,   /* Ring 2 */
			             <GIC_SPI 4 IRQ_TYPE_LEVEL_HIGH>,   /* Ring 3 */
			             <GIC_SPI 5 IRQ_TYPE_LEVEL_HIGH>,   /* MAC 0 */
			             <GIC_SPI 6 IRQ_TYPE_LEVEL_HIGH>,   /* MAC 1 */
			             <GIC_SPI 7 IRQ_TYPE_LEVEL_HIGH>,   /* MAC 2 */
			             <GIC_SPI 8 IRQ_TYPE_LEVEL_HIGH>,   /* MAC 3 */
			             <GIC_SPI 9 IRQ_TYPE_LEVEL_HIGH>;   /* MAC 4 */
			interrupt-names = "eip197", "ring0", "ring1", "ring2", "ring3",
			                  "mac0", "mac1", "mac2", "mac3", "mac4";
			status = "disabled";

			/* MAC 0: 10G RXAUI */
			mac0: mac@0 {
				compatible = "axiado,ax3000-mac";
				reg = <0>;
				phy-mode = "rxaui";
				status = "disabled";
			};

			/* MAC 1: 1G SGMII */
			mac1: mac@1 {
				compatible = "axiado,ax3000-mac";
				reg = <1>;
				phy-mode = "sgmii";
				status = "disabled";
			};

			/* MAC 2: 1G SGMII */
			mac2: mac@2 {
				compatible = "axiado,ax3000-mac";
				reg = <2>;
				phy-mode = "sgmii";
				status = "disabled";
			};

			/* MAC 3: 1G SGMII */
			mac3: mac@3 {
				compatible = "axiado,ax3000-mac";
				reg = <3>;
				phy-mode = "sgmii";
				status = "disabled";
			};

			/* MAC 4: 1G SGMII */
			mac4: mac@4 {
				compatible = "axiado,ax3000-mac";
				reg = <4>;
				phy-mode = "sgmii";
				status = "disabled";
			};

			/* MDIO bus for PHY management */
			mdio: mdio {
				compatible = "axiado,ax3000-mdio";
				#address-cells = <1>;
				#size-cells = <0>;
			};
		};

		ax_logger_sysmgr: ax-log@800000 {
			compatible = "axiado,ax-logger";
			reg = <0x00 0x800000 0x00 0xfa00>;
			node-name = "log-sysmgr";
		};

		ax_logger_ml_0: ax-log@900000 {
			compatible = "axiado,ax-logger";
			reg = <0x00 0x900000 0x00 0xfa00>;
			node-name = "log-ml-0";
		};

		ax_logger_ml_1: ax-log@A00000 {
			compatible = "axiado,ax-logger";
			reg = <0x00 0xA00000 0x00 0xfa00>;
			node-name = "log-ml-1";
		};

		ax_logger_ml_2: ax-log@B00000 {
			compatible = "axiado,ax-logger";
			reg = <0x00 0xB00000 0x00 0xfa00>;
			node-name = "log-ml-2";
		};

		ax_logger_ml_3: ax-log@C00000 {
			compatible = "axiado,ax-logger";
			reg = <0x00 0xC00000 0x00 0xfa00>;
			node-name = "log-ml-3";
		};

		ax_logger_fwl: ax-log@D00000 {
			compatible = "axiado,ax-logger";
			reg = <0x00 0xD00000 0x00 0xfa00>;
			node-name = "log-fwl";
		};

		ax_logger_svt: ax-log@E00000 {
			compatible = "axiado,ax-logger";
			reg = <0x00 0xE00000 0x00 0xfa00>;
			node-name = "log-svt";
		};

		ax_board_info: board-info@80620808 {
			compatible = "axiado,board-id";
			reg = <0x0 0x80620808 0x0 0x4>;
			status = "okay";
		};

	};

	timer {
		compatible = "arm,armv8-timer";
		interrupt-parent = <&gic500>;
		interrupts = <GIC_PPI 13 IRQ_TYPE_LEVEL_HIGH>,
			   <GIC_PPI 14 IRQ_TYPE_LEVEL_HIGH>,
			   <GIC_PPI 11 IRQ_TYPE_LEVEL_HIGH>,
			   <GIC_PPI 10 IRQ_TYPE_LEVEL_HIGH>;
	};
};
