		};

		fan0: pwm-fan@80501400 {
			compatible = "axiado,ax3000-pwm-fan";
			interrupt-parent = <&gic500>;
			interrupts = <GIC_SPI 150 IRQ_TYPE_LEVEL_HIGH>;
			reg = <0x00 0x80501400 0x00 0x400>;
			pwms = <&pwm0 0 400>;
			status = "disabled";
		};

		fan1: pwm-fan@80501800 {
			compatible = "axiado,ax3000-pwm-fan";
			interrupt-parent = <&gic500>;
			interrupts = <GIC_SPI 151 IRQ_TYPE_LEVEL_HIGH>;
			reg = <0x00 0x80501800 0x00 0x400>;
			pwms = <&pwm1 0 400>;
			status = "disabled";
		};

		fan2: pwm-fan@80581400 {
			compatible = "axiado,ax3000-pwm-fan";
