&i2c16 {
	status = "okay";
	#address-cells = <1>;
	tmp75@4e {
		compatible = "tmp75";
		reg = <0x4e>;
		status = "okay";
	};
	tmp75@4f {
		compatible = "tmp75";
		reg = <0x4f>;
		status = "okay";
	};
	eeprom@50 {
		compatible = "atmel,24c16";
		reg = <0x50>;
		pagesize = <16>;
		status = "okay";
	};
};

