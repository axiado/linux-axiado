/dts-v1/;

#include "ax3005.dtsi"

/ {
	model = "Axiado AX3005 EVK";
	compatible = "axiado,ax3005-evk", "axiado,ax3005";
	#address-cells = <2>;
	#size-cells = <2>;

	aliases {
		serial0 = &uart0;
		serial1 = &uart1;
		serial2 = &uart2;
		serial3 = &uart3;
		serial4 = &uart4;
		serial5 = &uart5;
		serial6 = &uart6;
		serial7 = &uart7;
		serial8 = &uart8;
		i2c0 = &i2c0;
		i2c1 = &i2c1;
		i2c2 = &i2c2;
		i2c3 = &i2c3;
		i2c4 = &i2c4;
		i2c5 = &i2c5;
		i2c6 = &i3c6;
		i2c7 = &i3c7;
		i2c8 = &i3c8;
		i2c9 = &i3c9;
		i2c10 = &i2c10;
		i2c11 = &i2c11;
		i2c12 = &i3c12;
		i2c13 = &i3c13;
		i2c14 = &i2c14;
		i2c15 = &i2c15;
		i2c16 = &i2c16;
		i2c17 = &i2c17;
		i2c18 = &i2c18;
		i2c19 = &i2c19;
		i2c20 = &i2c20;
		i2c21 = &i2c21;
		i2c22 = &i3c22;
		i2c23 = &i2c23;
		i2c24 = &i2c24;
		i2c25 = &i2c25;
		i2c26 = &i2c26;
		i2c27 = &i2c27;
		i2c28 = &i2c28;
		i2c29 = &i2c29;
		i2c30 = &i2c30;
		i2c31 = &i2c31;
		spi0  = &spi0;
		spi1  = &spi1;
		spi2  = &spi2;
		spi3  = &spi3;
		spi5  = &spi5;
		spi6  = &spi6;
	};

	chosen {
		bootargs = "console=ttyPS3,115200 earlyprintk maxcpus=4 nr_cpus=4 earlycon";
		stdout-path = "serial3:115200";
	};

	memory@0 {
		device_type = "memory";
		/* Cortex-A53 will use following memory map */
		reg = <0x00000000 0x81000000 0x00000000 0x7f000000>;
	};
};

