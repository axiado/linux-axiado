	status = "okay";
};

&i3c5 {
	status = "okay";
};

&i3c6 {
	status = "okay";
};

&i3c7 {
	status = "okay";
};

&i3c8 {
	status = "okay";
};

&i3c9 {
	status = "okay";
};

&i3c10 {
	status = "okay";
};

&i3c11 {
