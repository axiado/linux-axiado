#include "ax3000-scm.dtsi"

/ {
	model = "Axiado AX3000-SCM3002";

	update: fw-update@4A00000 {
		compatible = "axiado,ax-fwupgrade";
		/* Reserved memory space for the firmware upgrade */
		reg = <0x00000000 0x04A00000 0x00000000 0x8000000>;
		status = "okay";
	};
};

/* GPIO bank 0 - 7 */
&gpio0 {
	status = "okay";
};

&gpio1 {
	status = "okay";
};

&gpio2 {
	status = "okay";
};

&gpio3 {
	status = "okay";
};

&gpio4 {
	status = "okay";
};

&gpio5 {
	status = "okay";
};

&gpio6 {
	status = "okay";
};

&gpio7 {
	status = "okay";
};

&uart0 {
	status = "okay";
};

&uart1 {
	status = "okay";
};

&uart2 {
	status = "okay";
};

&uart3 {
	status = "okay";
};

&usb2_0 {
	status = "okay";
};

&usb2_1 {
	status = "okay";
};

&emmc_phy {
	status = "okay";
};

&sdhci0 {
	status = "okay";
};

&spi2 {
	status = "okay";
	spi-bridge@0 {
		status = "okay";
		i2c-ssif@0 {
			status = "okay";
			ssif-bmc@10 {
				status = "okay";
			};
		};
	};
};

&i3c0 {
	status = "okay";
};

&i3c1 {
	status = "okay";
};

&i3c2 {
	status = "okay";
};

&i3c3 {
	status = "okay";
};

